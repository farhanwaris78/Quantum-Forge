<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<ScrollPane prefHeight="650.0" prefWidth="425.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
   <content>
      <VBox spacing="10.0">
         <children>
            <BorderPane prefWidth="395.0">
               <center>
                  <Separator prefHeight="30.0" BorderPane.alignment="CENTER" />
               </center>
               <left>
                  <Label styleClass="medium-text" text="Phonon Calculation (ph.x)" BorderPane.alignment="CENTER">
                     <font>
                        <Font name="System Bold Italic" size="14.0" />
                     </font>
                     <padding>
                        <Insets left="10.0" right="10.0" />
                     </padding>
                  </Label>
               </left>
               <padding>
                  <Insets top="10.0" />
               </padding>
            </BorderPane>
            <GridPane hgap="10.0" vgap="10.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="205.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="q-Grid (nq1,2,3)" />
                  <HBox spacing="5.0" GridPane.columnIndex="1">
                     <children>
                        <TextField fx:id="nq1Field" prefWidth="60.0" text="2" />
                        <TextField fx:id="nq2Field" prefWidth="60.0" text="2" />
                        <TextField fx:id="nq3Field" prefWidth="60.0" text="2" />
                     </children>
                  </HBox>
                  <Label text="Threshold (tr2_ph)" GridPane.rowIndex="1" />
                  <TextField fx:id="tr2phField" text="1.0d-12" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label text="Dielectric (epsil)" GridPane.rowIndex="2" />
                  <CheckBox fx:id="epsilCheck" mnemonicParsing="false" text="Compute dielectric" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label text="ASR" GridPane.rowIndex="3" />
                  <ComboBox fx:id="asrCombo" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
               </children>
               <padding>
                  <Insets left="10.0" />
               </padding>
            </GridPane>
            <Separator />
            <VBox spacing="5.0" style="-fx-background-color: #f0f8ff; -fx-padding: 10;">
               <children>
                  <Label text="How to avoid negative frequencies:">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
                  <Label text="1. Ensure structure is fully optimized (vc-relax)." wrapText="true" />
                  <Label text="2. Increase K-Points and Ecutwfc for better precision." wrapText="true" />
                  <Label text="3. Tighten conv_thr and tr2_ph (e.g., 1d-14)." wrapText="true" />
                  <Label text="4. Check if the cell has symmetry breaking." wrapText="true" />
               </children>
            </VBox>
            <Separator />
            <VBox spacing="5.0" style="-fx-background-color: #f8f4ff; -fx-padding: 10;">
               <children>
                  <Label text="ph.x keyword grammar window (typed against mined QE 7.2-7.6):" wrapText="true">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
                  <HBox spacing="5.0" alignment="CENTER_LEFT">
                     <children>
                        <Label text="Target QE version:" />
                        <ComboBox fx:id="qeVersionCombo" prefWidth="110.0" />
                     </children>
                  </HBox>
                  <Label text="Only keywords present in the selected version are listed. Version-gated entries (e.g. lmultipole 7.5+, skip_upperfan up to 7.4) never leak across windows." wrapText="true" />
                  <ListView fx:id="keywordWindowList" prefHeight="220.0" />
               </children>
            </VBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
