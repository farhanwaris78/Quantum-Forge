version             = 2.0.0
maximum_recents     = 64
default_website     = https://www.google.com
documents_website   = https://github.com/quantumforge/quantumforge
espresso_website    = http://www.quantum-espresso.org
pseudos_website     = https://www.materialscloud.org/discover/sssp/table
man_pwscf_website   = https://www.quantum-espresso.org/Doc/INPUT_PW.html
man_dos_website     = https://www.quantum-espresso.org/Doc/INPUT_DOS.html
man_projwfc_website = https://www.quantum-espresso.org/Doc/INPUT_PROJWFC.html
man_bands_website   = https://www.quantum-espresso.org/Doc/INPUT_BANDS.html
man_ph_website      = https://www.quantum-espresso.org/Doc/INPUT_PH.html
man_neb_website     = https://www.quantum-espresso.org/Doc/INPUT_NEB.html
man_pp_website      = https://www.quantum-espresso.org/Doc/INPUT_PP.html
thermo_pw_website   = https://dalcorso.github.io/thermo_pw/
phonopy_website     = https://phonopy.github.io/phonopy/
boltztrap2_website  = https://www.simsa.org/boltztrap2/
command_mpirun      = mpiexec.exe -n $NP
command_pwscf       = pw.x -in $IN
command_dos         = dos.x -in $IN
command_projwfc     = projwfc.x -in $IN
command_band        = bands.x -in $IN
command_ph          = ph.x -in $IN
command_neb         = neb.x -in $IN
command_pp          = pp.x -in $IN
command_pwe3        = pw2ebands.x -in $IN
command_wannier90   = wannier90.x -in $IN
